<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Grocery.App.ViewModels"
             x:Class="Grocery.App.Views.CategoriesView"
             x:DataType="vm:CategoriesViewModel"
             Title="CategoriesView">
    <StackLayout Padding="20" VerticalOptions="Center">
        <Label Text="Categories View" FontSize="24" HorizontalOptions="Center" />
		      <Button Text="Laad Categorieën" Command="{Binding SelectCategoryCommand}" />
        <CollectionView ItemsSource="{Binding Categories}" SelectionMode="Single" SelectedItem="{Binding CategoryName}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Padding="10" Margin="5" BorderColor="LightGray" CornerRadius="5">
                        <Label Text="{Binding CategoryName}" FontSize="18" />
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
		</CollectionView>
	</StackLayout>
</ContentPage>